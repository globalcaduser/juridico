    function renderAll() {
      updateResponsavelSelects();
      renderBoard();
      renderMetrics();
      renderUpcoming();
    }

    function getFilteredDemandas() {
      const search = getValue("searchInput").toLowerCase();
      const tipo = getValue("filterTipo");
      const area = getValue("filterArea");
      const risco = getValue("filterRisco");
      const responsavel = getValue("filterResponsavel");

      return demandas.filter((d) => {
        const resp = getResponsavel(d.responsavel_id);

        const text = [
          d.codigo,
          d.titulo,
          d.descricao,
          d.area_juridica,
          d.risco,
          d.prioridade,
          d.numero_processo,
          d.parte_contraria,
          resp?.nome,
          resp?.email
        ].join(" ").toLowerCase();

        return (!search || text.includes(search)) &&
          (!tipo || d.tipo_registro === tipo) &&
          (!area || d.area_juridica === area) &&
          (!risco || d.risco === risco) &&
          (!responsavel || d.responsavel_id === responsavel);
      });
    }

    function renderBoard() {
      const board = document.getElementById("board");
      const filtered = getFilteredDemandas();

      board.innerHTML = STATUSES.map((status) => {
        const cards = filtered.filter((d) => d.status === status.id);

        return `
          <div class="column">
            <div class="column-header">
              <h3>
                <span class="dot" style="background:${status.color}"></span>
                ${status.label}
              </h3>
              <span class="count">${cards.length}</span>
            </div>

            <div
              class="dropzone"
              data-status="${status.id}"
              ondragover="allowDrop(event)"
              ondragleave="leaveDrop(event)"
              ondrop="dropCard(event)"
            >
              ${cards.length ? cards.map(renderCard).join("") : `<div class="empty">Nenhum item nesta etapa.</div>`}
            </div>
          </div>
        `;
      }).join("");
    }

    function renderCard(d) {
      const resp = getResponsavel(d.responsavel_id);
      const checklist = Array.isArray(d.checklist) ? d.checklist : [];
      const done = checklist.filter((c) => c.done).length;
      const prazoClass = getPrazoClass(d.prazo);

      return `
        <article class="card" draggable="true" ondragstart="dragCard(event, '${d.id}')" ondblclick="editDemanda('${d.id}')">
          <h4>${escapeHtml(d.titulo)}</h4>
          <div class="code">${escapeHtml(d.codigo || d.id)}</div>

          <div class="badges">
            <span class="badge badge-${d.tipo_registro}">
              ${d.tipo_registro === "tarefa" ? "Tarefa" : "Demanda"}
            </span>

            <span class="badge badge-${d.prioridade}">
              ${labelPrioridade(d.prioridade)}
            </span>

            <span class="badge badge-${d.risco}">
              Risco ${labelRisco(d.risco)}
            </span>
          </div>

          <div class="description">
            ${escapeHtml(d.descricao || "Sem descrição.")}
          </div>

          <div class="meta">
            <div>⚖ ${labelArea(d.area_juridica)}</div>
            <div class="${prazoClass}">⏱ ${formatDate(d.prazo) || "Sem prazo"}</div>
            ${d.numero_processo ? `<div># ${escapeHtml(d.numero_processo)}</div>` : ""}
            ${checklist.length ? `<div>☑ Checklist: ${done}/${checklist.length}</div>` : ""}
            ${d.valor_envolvido ? `<div>💰 ${formatMoney(d.valor_envolvido)}</div>` : ""}
          </div>

          <div class="card-footer">
            <div style="font-size:12px;color:var(--muted);font-weight:700">
              ${escapeHtml(resp?.nome || "Sem responsável")}
            </div>

            <button class="btn btn-secondary btn-small" onclick="event.stopPropagation(); editDemanda('${d.id}')">
              Editar
            </button>
          </div>
        </article>
      `;
    }

    function renderMetrics() {
      const today = new Date();
      today.setHours(0, 0, 0, 0);

      const vencidas = demandas.filter((d) => {
        if (!d.prazo || d.status === "concluido") return false;
        const date = new Date(d.prazo + "T00:00:00");
        return date <= today;
      }).length;

      document.getElementById("metricTotal").textContent = demandas.length;
      document.getElementById("metricPrazo").textContent = vencidas;
      document.getElementById("metricCritico").textContent = demandas.filter((d) => ["alto", "critico"].includes(d.risco)).length;
      document.getElementById("metricConcluido").textContent = demandas.filter((d) => d.status === "concluido").length;
    }

    function renderUpcoming() {
      const el = document.getElementById("upcomingList");

      const upcoming = demandas
        .filter((d) => d.prazo && d.status !== "concluido")
        .sort((a, b) => new Date(a.prazo) - new Date(b.prazo))
        .slice(0, 6);

      if (!upcoming.length) {
        el.innerHTML = `<div class="empty">Sem prazos cadastrados.</div>`;
        return;
      }

      el.innerHTML = upcoming.map((d) => `
        <div style="padding:9px 0;border-bottom:1px solid var(--border)">
          <strong style="font-size:13px">${escapeHtml(d.titulo)}</strong>
          <div style="font-size:12px;margin-top:4px" class="${getPrazoClass(d.prazo)}">
            ${formatDate(d.prazo)} · ${labelArea(d.area_juridica)}
          </div>
        </div>
      `).join("");
    }

    function updateResponsavelSelects() {
      const options = responsaveis.map((r) => `<option value="${r.id}">${escapeHtml(r.nome)}</option>`).join("");

      document.getElementById("responsavelSelect").innerHTML =
        `<option value="">Sem responsável</option>${options}`;

      document.getElementById("filterResponsavel").innerHTML =
        `<option value="">Todos</option>${options}`;
    }

    function newDemanda() {
      clearDemandaForm();
      document.getElementById("demandaModalTitle").textContent = "Nova demanda/tarefa";
      document.getElementById("deleteBtn").style.display = "none";
      openModal("demandaModal");
    }

    function editDemanda(id) {
      const d = demandas.find((x) => x.id === id);
      if (!d) return;

      setValue("demandaId", d.id);
      setValue("tipoRegistro", d.tipo_registro);
      setValue("status", d.status);
      setValue("prioridade", d.prioridade);
      setValue("titulo", d.titulo);
      setValue("descricao", d.descricao);
      setValue("areaJuridica", d.area_juridica);
      setValue("risco", d.risco);
      setValue("responsavelSelect", d.responsavel_id || "");
      setValue("prazo", d.prazo || "");
      setValue("numeroProcesso", d.numero_processo || "");
      setValue("valorEnvolvido", d.valor_envolvido || "");
      setValue("parteContraria", d.parte_contraria || "");
      setValue("linkDocumento", d.link_documento || "");

      checklistAtual = Array.isArray(d.checklist) ? [...d.checklist] : [];

      document.getElementById("demandaModalTitle").textContent = "Editar demanda/tarefa";
      document.getElementById("deleteBtn").style.display = "inline-flex";

      renderChecklist();
      openModal("demandaModal");
    }

    async function saveDemanda() {
      const id = getValue("demandaId");

      const payload = {
        tipo_registro: getValue("tipoRegistro"),
        status: getValue("status"),
        prioridade: getValue("prioridade"),
        titulo: getValue("titulo"),
        descricao: getValue("descricao"),
        area_juridica: getValue("areaJuridica"),
        risco: getValue("risco"),
        responsavel_id: getValue("responsavelSelect") || null,
        prazo: getValue("prazo") || null,
        numero_processo: getValue("numeroProcesso"),
        parte_contraria: getValue("parteContraria"),
        valor_envolvido: getValue("valorEnvolvido") ? Number(getValue("valorEnvolvido")) : null,
        link_documento: getValue("linkDocumento"),
        checklist: checklistAtual
      };

      if (!payload.titulo) {
        toast("Informe o título.");
        return;
      }

      if (!supabaseClient) {
        if (id) {
          const index = demandas.findIndex((d) => d.id === id);
          demandas[index] = { ...demandas[index], ...payload };
        } else {
          demandas.unshift({
            id: "local-" + Date.now(),
            codigo: nextLocalCode(),
            ...payload
          });
        }

        closeModal("demandaModal");
        renderAll();
        toast("Salvo localmente. Configure o Supabase para persistir.");
        return;
      }

      if (id) {
        const { error } = await supabaseClient
          .from("jur_demandas")
          .update(payload)
          .eq("id", id);

        if (error) {
          toast(error.message);
          return;
        }
      } else {
        payload.codigo = await nextCode();

        const { error } = await supabaseClient
          .from("jur_demandas")
          .insert(payload);

        if (error) {
          toast(error.message);
          return;
        }
      }

      closeModal("demandaModal");
      clearDemandaForm();
      await refresh();
      toast("Registro salvo.");
    }

    async function deleteDemanda() {
      const id = getValue("demandaId");
      if (!id) return;

      if (!confirm("Deseja excluir este registro?")) return;

      if (!supabaseClient) {
        demandas = demandas.filter((d) => d.id !== id);
        closeModal("demandaModal");
        renderAll();
        toast("Registro excluído localmente.");
        return;
      }

      const { error } = await supabaseClient
        .from("jur_demandas")
        .delete()
        .eq("id", id);

      if (error) {
        toast(error.message);
        return;
      }

      closeModal("demandaModal");
      await refresh();
      toast("Registro excluído.");
    }

    async function saveResponsavel() {
      const payload = {
        nome: getValue("responsavelNome"),
        email: getValue("responsavelEmail"),
        cargo: getValue("responsavelCargo"),
        cor: getValue("responsavelCor") || "#2563eb"
      };

      if (!payload.nome) {
        toast("Informe o nome do responsável.");
        return;
      }

      if (!supabaseClient) {
        responsaveis.push({
          id: "local-resp-" + Date.now(),
          ...payload
        });

        closeModal("responsavelModal");
        clearResponsavelForm();
        renderAll();
        toast("Responsável salvo localmente.");
        return;
      }

      const { error } = await supabaseClient
        .from("jur_responsaveis")
        .insert(payload);

      if (error) {
        toast(error.message);
        return;
      }

      closeModal("responsavelModal");
      clearResponsavelForm();
      await refresh();
      toast("Responsável salvo.");
    }

    function addChecklistItem() {
      const text = getValue("checkInput");
      if (!text) return;

      checklistAtual.push({
        text,
        done: false
      });

      setValue("checkInput", "");
      renderChecklist();
    }

    function toggleChecklist(index) {
      checklistAtual[index].done = !checklistAtual[index].done;
      renderChecklist();
    }

    function removeChecklist(index) {
      checklistAtual.splice(index, 1);
      renderChecklist();
    }

    function renderChecklist() {
      const box = document.getElementById("checklistBox");

      if (!checklistAtual.length) {
        box.innerHTML = `<div class="empty">Nenhuma tarefa no checklist.</div>`;
        return;
      }

      box.innerHTML = checklistAtual.map((item, index) => `
        <div class="checkline">
          <input type="checkbox" ${item.done ? "checked" : ""} onchange="toggleChecklist(${index})" />
          <span style="${item.done ? "text-decoration:line-through;color:var(--muted)" : ""}">
            ${escapeHtml(item.text)}
          </span>
          <button class="btn btn-danger btn-small" type="button" onclick="removeChecklist(${index})">x</button>
        </div>
      `).join("");
    }

    function dragCard(event, id) {
      draggedId = id;
      event.dataTransfer.effectAllowed = "move";
    }

    function allowDrop(event) {
      event.preventDefault();
      event.currentTarget.classList.add("drag-over");
    }

    function leaveDrop(event) {
      event.currentTarget.classList.remove("drag-over");
    }

    async function dropCard(event) {
      event.preventDefault();
      event.currentTarget.classList.remove("drag-over");

      const status = event.currentTarget.dataset.status;
      if (!draggedId || !status) return;

      if (!supabaseClient) {
        const item = demandas.find((d) => d.id === draggedId);
        if (item) item.status = status;
        renderAll();
        return;
      }

      const { error } = await supabaseClient
        .from("jur_demandas")
        .update({ status })
        .eq("id", draggedId);

      if (error) {
        toast(error.message);
        return;
      }

      await refresh();
      toast("Status atualizado.");
    }

    function saveConfig() {
      localStorage.setItem("JUR_SUPABASE_URL", getValue("supabaseUrl"));
      localStorage.setItem("JUR_SUPABASE_KEY", getValue("supabaseKey"));
      location.reload();
    }

    function clearFilters() {
      setValue("searchInput", "");
      setValue("filterTipo", "");
      setValue("filterArea", "");
      setValue("filterRisco", "");
      setValue("filterResponsavel", "");
      renderAll();
    }

    function clearDemandaForm() {
      [
        "demandaId",
        "titulo",
        "descricao",
        "prazo",
        "numeroProcesso",
        "valorEnvolvido",
        "parteContraria",
        "linkDocumento",
        "checkInput"
      ].forEach((id) => setValue(id, ""));

      setValue("tipoRegistro", "demanda");
      setValue("status", "triagem");
      setValue("prioridade", "media");
      setValue("areaJuridica", "contratos");
      setValue("risco", "medio");
      setValue("responsavelSelect", "");

      checklistAtual = [];
      renderChecklist();
    }

    function clearResponsavelForm() {
      setValue("responsavelId", "");
      setValue("responsavelNome", "");
      setValue("responsavelEmail", "");
      setValue("responsavelCargo", "");
      setValue("responsavelCor", "#2563eb");
    }

    function openModal(id) {
      document.getElementById(id).classList.add("active");
    }

    function closeModal(id) {
      document.getElementById(id).classList.remove("active");
    }

    document.querySelectorAll(".modal-overlay").forEach((modal) => {
      modal.addEventListener("click", (event) => {
        if (event.target === modal) modal.classList.remove("active");
      });
    });

    async function nextCode() {
      const year = new Date().getFullYear();
      const count = demandas.filter((d) => String(d.codigo || "").includes(`JUR-${year}`)).length + 1;
      return `JUR-${year}-${String(count).padStart(4, "0")}`;
    }

    function nextLocalCode() {
      const year = new Date().getFullYear();
      return `JUR-${year}-${String(demandas.length + 1).padStart(4, "0")}`;
    }

    function getResponsavel(id) {
      return responsaveis.find((r) => r.id === id);
    }

    function getPrazoClass(date) {
      if (!date) return "";

      const today = new Date();
      today.setHours(0, 0, 0, 0);

      const prazo = new Date(date + "T00:00:00");
      const diff = Math.ceil((prazo - today) / 86400000);

      if (diff < 0) return "overdue";
      if (diff <= 2) return "due-soon";
      return "";
    }

    function labelArea(value) {
      return {
        contratos: "Contratos",
        trabalhista: "Trabalhista",
        civel: "Cível",
        tributario: "Tributário",
        societario: "Societário",
        compliance: "Compliance",
        lgpd: "LGPD",
        administrativo: "Administrativo"
      }[value] || value || "—";
    }

    function labelPrioridade(value) {
      return {
        baixa: "Baixa",
        media: "Média",
        alta: "Alta",
        critico: "Crítica"
      }[value] || value || "—";
    }

    function labelRisco(value) {
      return {
        baixo: "Baixo",
        medio: "Médio",
        alto: "Alto",
        critico: "Crítico"
      }[value] || value || "—";
    }

    function formatDate(date) {
      if (!date) return "";
      const [year, month, day] = date.split("-");
      return `${day}/${month}/${year}`;
    }

    function formatMoney(value) {
      return Number(value || 0).toLocaleString("pt-BR", {
        style: "currency",
        currency: "BRL"
      });
    }

    function addDays(date, days) {
      const d = new Date(date);
      d.setDate(d.getDate() + days);
      return d;
    }

    function toISODate(date) {
      return date.toISOString().slice(0, 10);
    }

    function getValue(id) {
      return document.getElementById(id)?.value?.trim() || "";
    }

    function setValue(id, value) {
      const el = document.getElementById(id);
      if (el) el.value = value ?? "";
    }

    function escapeHtml(value) {
      return String(value ?? "").replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#039;"
      }[char]));
    }

    function toast(message) {
      const el = document.getElementById("toast");
      el.textContent = message;
      el.classList.add("show");
      setTimeout(() => el.classList.remove("show"), 3200);
    }
  </script>
</body>
