  <script>
    const STATUSES = [
      { id: "triagem", label: "Triagem", color: "#556080" },
      { id: "em_analise", label: "Em análise", color: "#4a80f5" },
      { id: "em_execucao", label: "Em execução", color: "#f5a623" },
      { id: "aguardando", label: "Aguardando terceiro", color: "#9b6bff" },
      { id: "concluido", label: "Concluído", color: "#2ecc87" }
    ];

    const STATUS_LABEL = Object.fromEntries(STATUSES.map(s => [s.id, s.label]));

    let supabaseClient = null;
    let demandas = [];
    let responsaveis = [];
    let checklistAtual = [];
    let draggedId = null;
    let currentView = "kanban";

    const config = {
      url: localStorage.getItem("JUR_SUPABASE_URL") || "",
      key: localStorage.getItem("JUR_SUPABASE_KEY") || ""
    };

    document.addEventListener("DOMContentLoaded", init);

    async function init() {
      setValue("supabaseUrl", config.url);
      setValue("supabaseKey", config.key);

      if (!config.url || !config.key) {
        seedDemo();
        renderAll();
        openModal("configModal");
        toast("Configure o Supabase para persistir dados reais.", "info");
        return;
      }

      supabaseClient = supabase.createClient(config.url, config.key);

      await loadData();
      initRealtime();
      renderAll();
    }

    async function loadData() {
      const [respRes, demRes] = await Promise.all([
        supabaseClient.from("jur_responsaveis").select("*").order("nome"),
        supabaseClient.from("jur_demandas").select("*").order("created_at", { ascending: false })
      ]);

      if (respRes.error) {
        toast(respRes.error.message, "error");
        return;
      }

      if (demRes.error) {
        toast(demRes.error.message, "error");
        return;
      }

      responsaveis = respRes.data || [];
      demandas = demRes.data || [];
    }

    function initRealtime() {
      supabaseClient
        .channel("juridico-lexboard")
        .on("postgres_changes", { event: "*", schema: "public", table: "jur_responsaveis" }, refresh)
        .on("postgres_changes", { event: "*", schema: "public", table: "jur_demandas" }, refresh)
        .subscribe();
    }

    async function refresh() {
      await loadData();
      renderAll();
    }

    function seedDemo() {
