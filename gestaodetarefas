    function renderAll() {
      updateResponsavelSelects();
      renderBoard();
      renderListView();
      renderMetrics();
      renderUpcoming();
      renderUsersGrid();
    }

    function getFilteredDemandas() {
      const search = getValue("searchInput").toLowerCase();
      const tipo = getValue("filterTipo");
      const area = getValue("filterArea");
      const risco = getValue("filterRisco");
      const respFilt = getValue("filterResponsavel");

      return demandas.filter(d => {
        const resp = getResponsavel(d.responsavel_id);
        const text = [
          d.codigo,
          d.titulo,
          d.descricao,
          d.area_juridica,
          d.numero_processo,
          d.parte_contraria,
          resp?.nome,
          resp?.email
        ].join(" ").toLowerCase();

        return (!search || text.includes(search))
          && (!tipo || d.tipo_registro === tipo)
          && (!area || d.area_juridica === area)
          && (!risco || d.risco === risco)
          && (!respFilt || d.responsavel_id === respFilt);
      });
    }

    function renderBoard() {
      const board = document.getElementById("boardKanban");
      const filtered = getFilteredDemandas();

      board.innerHTML = STATUSES.map(s => {
        const cards = filtered.filter(d => d.status === s.id);

        return `
          <div class="column">
            <div class="column-header">
              <h3><span class="dot" style="background:${s.color}"></span>${s.label}</h3>
              <span class="count">${cards.length}</span>
            </div>
            <div class="dropzone" data-status="${s.id}" ondragover="allowDrop(event)" ondragleave="leaveDrop(event)" ondrop="dropCard(event)">
              ${cards.length ? cards.map(renderCard).join("") : '<div class="empty">Arraste cartões aqui</div>'}
            </div>
          </div>
        `;
      }).join("");
    }

    function renderCard(d) {
      const resp = getResponsavel(d.responsavel_id);
      const cl = Array.isArray(d.checklist) ? d.checklist : [];
      const done = cl.filter(c => c.done).length;
      const prazoClass = getPrazoClass(d.prazo);
      const iniciais = resp ? resp.nome.split(" ").map(w => w[0]).slice(0, 2).join("").toUpperCase() : "?";
      const cor = resp?.cor || "#556080";

      return `
        <article class="card prio-${d.prioridade}" draggable="true" ondragstart="dragCard(event,'${d.id}')" ondblclick="editDemanda('${d.id}')">
          <h4>${escapeHtml(d.titulo)}</h4>
          <div class="card-code">${escapeHtml(d.codigo || d.id)}</div>

          <div class="badges">
            <span class="badge badge-${d.tipo_registro}">${d.tipo_registro === "tarefa" ? "Tarefa" : "Demanda"}</span>
            <span class="badge badge-${d.prioridade}">${labelPrioridade(d.prioridade)}</span>
            <span class="badge badge-${d.risco}">Risco ${labelRisco(d.risco)}</span>
          </div>

          ${d.descricao ? `<div class="card-desc">${escapeHtml(d.descricao).slice(0, 120)}${d.descricao.length > 120 ? "…" : ""}</div>` : ""}

          <div class="card-meta">
            <div>⚖ ${labelArea(d.area_juridica)}</div>
            <div class="${prazoClass}">⏱ ${formatDate(d.prazo) || "Sem prazo"}</div>
            ${d.numero_processo ? `<div>📄 ${escapeHtml(d.numero_processo)}</div>` : ""}
            ${cl.length ? `<div>☑ ${done}/${cl.length} checklist</div>` : ""}
            ${d.valor_envolvido ? `<div>💰 ${formatMoney(d.valor_envolvido)}</div>` : ""}
          </div>

          <div class="card-footer">
            <div class="resp-label">
              <span class="avatar" style="background:${cor}">${iniciais}</span>
              ${escapeHtml(resp?.nome || "Sem responsável")}
            </div>
            <button class="btn btn-ghost btn-xs" onclick="event.stopPropagation();editDemanda('${d.id}')">Editar</button>
          </div>
        </article>
      `;
    }

    function renderListView() {
      const board = document.getElementById("boardLista");
      const filtered = getFilteredDemandas();

      if (!filtered.length) {
        board.innerHTML = '<div class="empty" style="padding:48px">Nenhum registro encontrado.</div>';
        return;
      }

      board.innerHTML = `
        <table style="width:100%;border-collapse:collapse;font-size:13px">
          <thead>
            <tr style="border-bottom:1px solid var(--border)">
              ${["Código","Título","Tipo","Status","Prioridade","Risco","Área","Responsável","Prazo","Valor",""].map(h =>
                `<th style="padding:10px 12px;text-align:left;color:var(--text3);font-size:11px;text-transform:uppercase;letter-spacing:.06em">${h}</th>`
              ).join("")}
            </tr>
          </thead>
          <tbody>
            ${filtered.map(d => {
              const resp = getResponsavel(d.responsavel_id);
              const prazoClass = getPrazoClass(d.prazo);
              return `
                <tr style="border-bottom:1px solid var(--border)" ondblclick="editDemanda('${d.id}')">
                  <td style="padding:10px 12px;font-family:monospace;font-size:11px;color:var(--text3)">${escapeHtml(d.codigo || "")}</td>
                  <td style="padding:10px 12px;font-weight:600">${escapeHtml(d.titulo)}</td>
                  <td style="padding:10px 12px"><span class="badge badge-${d.tipo_registro}">${d.tipo_registro === "tarefa" ? "Tarefa" : "Demanda"}</span></td>
                  <td style="padding:10px 12px;color:var(--text2)">${STATUS_LABEL[d.status] || d.status}</td>
                  <td style="padding:10px 12px"><span class="badge badge-${d.prioridade}">${labelPrioridade(d.prioridade)}</span></td>
                  <td style="padding:10px 12px"><span class="badge badge-${d.risco}">Risco ${labelRisco(d.risco)}</span></td>
                  <td style="padding:10px 12px;color:var(--text2)">${labelArea(d.area_juridica)}</td>
                  <td style="padding:10px 12px;color:var(--text2)">${escapeHtml(resp?.nome || "—")}</td>
                  <td style="padding:10px 12px" class="${prazoClass}">${formatDate(d.prazo) || "—"}</td>
                  <td style="padding:10px 12px;color:var(--text2)">${d.valor_envolvido ? formatMoney(d.valor_envolvido) : "—"}</td>
                  <td style="padding:10px 12px"><button class="btn btn-ghost btn-xs" onclick="editDemanda('${d.id}')">Editar</button></td>
                </tr>
              `;
            }).join("")}
          </tbody>
        </table>
      `;
    }

    function switchView(view, btn) {
      currentView = view;
      document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      document.getElementById("boardKanban").style.display = view === "kanban" ? "" : "none";
      document.getElementById("boardLista").style.display = view === "lista" ? "" : "none";
    }

    function renderMetrics() {
      const today = new Date();
      today.setHours(0, 0, 0, 0);

      const vencidas = demandas.filter(d => {
        if (!d.prazo || d.status === "concluido") return false;
        return new Date(d.prazo + "T00:00:00") <= today;
      }).length;

      document.getElementById("metricTotal").textContent = demandas.length;
      document.getElementById("metricPrazo").textContent = vencidas;
      document.getElementById("metricCritico").textContent = demandas.filter(d => ["alto", "critico"].includes(d.risco)).length;
      document.getElementById("metricConcluido").textContent = demandas.filter(d => d.status === "concluido").length;
    }

    function renderUpcoming() {
      const el = document.getElementById("upcomingList");

      const items = demandas
        .filter(d => d.prazo && d.status !== "concluido")
        .sort((a, b) => new Date(a.prazo) - new Date(b.prazo))
        .slice(0, 7);

      if (!items.length) {
        el.innerHTML = '<div class="empty">Sem prazos.</div>';
        return;
      }

      el.innerHTML = items.map(d => `
        <div class="upcoming-item" onclick="editDemanda('${d.id}')">
          <div class="upcoming-title">${escapeHtml(d.titulo)}</div>
          <div class="upcoming-date ${getPrazoClass(d.prazo)}">⏱ ${formatDate(d.prazo)} · ${labelArea(d.area_juridica)}</div>
        </div>
      `).join("");
    }

    function updateResponsavelSelects() {
      const opts = responsaveis.map(r => `<option value="${r.id}">${escapeHtml(r.nome)}</option>`).join("");

      document.getElementById("responsavelSelect").innerHTML = `<option value="">Sem responsável</option>${opts}`;
      document.getElementById("filterResponsavel").innerHTML = `<option value="">Todos</option>${opts}`;
    }

    function renderUsersGrid() {
      const el = document.getElementById("usersGrid");

      if (!responsaveis.length) {
        el.innerHTML = '<div class="empty">Nenhum usuário cadastrado.</div>';
        return;
      }

      el.innerHTML = responsaveis.map(r => {
        const iniciais = r.nome.split(" ").map(w => w[0]).slice(0, 2).join("").toUpperCase();
        const qtd = demandas.filter(d => d.responsavel_id === r.id).length;

        return `
          <div class="user-row">
            <span class="avatar" style="background:${r.cor || '#4a80f5'};width:36px;height:36px;font-size:14px">${iniciais}</span>
            <div class="user-info">
              <div class="user-name">${escapeHtml(r.nome)}</div>
              <div class="user-meta">${escapeHtml(r.cargo || "")}${r.email ? " · " + escapeHtml(r.email) : ""} · ${qtd} tarefa(s)</div>
            </div>
            <button class="btn btn-ghost btn-xs" onclick="editUser('${r.id}')">Editar</button>
            <button class="btn btn-danger btn-xs" onclick="deleteUser('${r.id}')">✕</button>
          </div>
        `;
      }).join("");
    }

    async function saveUser() {
      const id = getValue("uId");

      const payload = {
        nome: getValue("uNome"),
        email: getValue("uEmail"),
        cargo: getValue("uCargo"),
        cor: document.getElementById("uCor").value || "#4a80f5",
        alertas_email: true,
        alerta_status: getValue("uAlertaStatus") === "true",
        alerta_prazo: getValue("uAlertaPrazo") === "true",
        alerta_atrib: true
      };

      if (!payload.nome) {
        toast("Informe o nome.", "error");
        return;
      }

      if (!supabaseClient) {
        if (id) {
          const i = responsaveis.findIndex(r => r.id === id);
          if (i >= 0) responsaveis[i] = { ...responsaveis[i], ...payload };
        } else {
          responsaveis.push({ id: "local-r-" + Date.now(), ...payload });
        }

        clearUserForm();
        renderAll();
        toast("Usuário salvo localmente.");
        return;
      }

      let error;

      if (id) {
        ({ error } = await supabaseClient.from("jur_responsaveis").update(payload).eq("id", id));
      } else {
        ({ error } = await supabaseClient.from("jur_responsaveis").insert(payload));
      }

      if (error) {
        toast(error.message, "error");
        return;
      }

      clearUserForm();
      await refresh();
      toast("Usuário salvo.");
    }

    function editUser(id) {
      const r = responsaveis.find(x => x.id === id);
      if (!r) return;

      setValue("uId", r.id);
      setValue("uNome", r.nome);
      setValue("uEmail", r.email || "");
      setValue("uCargo", r.cargo || "");
      document.getElementById("uCor").value = r.cor || "#4a80f5";
      setValue("uAlertaStatus", String(r.alerta_status !== false));
      setValue("uAlertaPrazo", String(r.alerta_prazo !== false));
    }

    async function deleteUser(id) {
      if (!confirm("Excluir este usuário?")) return;

      if (!supabaseClient) {
        responsaveis = responsaveis.filter(r => r.id !== id);
        renderAll();
        toast("Usuário excluído.");
        return;
      }

      const { error } = await supabaseClient.from("jur_responsaveis").delete().eq("id", id);

      if (error) {
        toast(error.message, "error");
        return;
      }

      await refresh();
      toast("Usuário excluído.");
    }

    function clearUserForm() {
      ["uId", "uNome", "uEmail", "uCargo"].forEach(id => setValue(id, ""));
      document.getElementById("uCor").value = "#4a80f5";
      setValue("uAlertaStatus", "true");
      setValue("uAlertaPrazo", "true");
    }

    function newDemanda() {
      clearDemandaForm();
      document.getElementById("demandaModalTitle").textContent = "Nova demanda/tarefa";
      document.getElementById("deleteBtn").style.display = "none";
      openModal("demandaModal");
    }

    function editDemanda(id) {
      const d = demandas.find(x => x.id === id);
      if (!d) return;

      setValue("demandaId", d.id);
      setValue("demandaOldStatus", d.status);
      setValue("demandaOldResp", d.responsavel_id || "");
      setValue("tipoRegistro", d.tipo_registro);
      setValue("status", d.status);
      setValue("prioridade", d.prioridade);
      setValue("titulo", d.titulo);
      setValue("descricao", d.descricao || "");
      setValue("areaJuridica", d.area_juridica);
      setValue("risco", d.risco);
      setValue("responsavelSelect", d.responsavel_id || "");
      setValue("prazo", d.prazo || "");
      setValue("numeroProcesso", d.numero_processo || "");
      setValue("valorEnvolvido", d.valor_envolvido || "");
      setValue("parteContraria", d.parte_contraria || "");
      setValue("linkDocumento", d.link_documento || "");

      checklistAtual = Array.isArray(d.checklist) ? [...d.checklist] : [];

      renderChecklist();

      document.getElementById("demandaModalTitle").textContent = "Editar demanda/tarefa";
      document.getElementById("deleteBtn").style.display = "inline-flex";
      openModal("demandaModal");
    }

    async function saveDemanda() {
      const id = getValue("demandaId");
      const oldStatus = getValue("demandaOldStatus");
      const oldResp = getValue("demandaOldResp");
      const newStatus = getValue("status");
      const newResp = getValue("responsavelSelect");

      const payload = {
        tipo_registro: getValue("tipoRegistro"),
        status: newStatus,
        prioridade: getValue("prioridade"),
        titulo: getValue("titulo"),
        descricao: getValue("descricao"),
        area_juridica: getValue("areaJuridica"),
        risco: getValue("risco"),
        responsavel_id: newResp || null,
        prazo: getValue("prazo") || null,
        numero_processo: getValue("numeroProcesso"),
        parte_contraria: getValue("parteContraria"),
        valor_envolvido: getValue("valorEnvolvido") ? Number(getValue("valorEnvolvido")) : null,
        link_documento: getValue("linkDocumento"),
        checklist: checklistAtual
      };

      if (!payload.titulo) {
        toast("Informe o título.", "error");
        return;
      }

      const histEntries = [];

      if (id && oldStatus && oldStatus !== newStatus) {
        histEntries.push({
          msg: `Status alterado: ${STATUS_LABEL[oldStatus] || oldStatus} → ${STATUS_LABEL[newStatus] || newStatus}`,
          data: new Date().toISOString()
        });
      }

      if (id && oldResp !== newResp) {
        const nr = getResponsavel(newResp);
        histEntries.push({
          msg: `Responsável alterado para: ${nr?.nome || "nenhum"}`,
          data: new Date().toISOString()
        });
      }

      if (!supabaseClient) {
        if (id) {
          const i = demandas.findIndex(d => d.id === id);
          const prev = demandas[i];
          const hist = [...(Array.isArray(prev.historico) ? prev.historico : []), ...histEntries];

          demandas[i] = {
            ...prev,
            ...payload,
            historico: hist,
            updated_at: new Date().toISOString()
          };
        } else {
          demandas.unshift({
            id: "local-" + Date.now(),
            codigo: nextLocalCode(),
            ...payload,
            historico: [{ msg: "Criado", data: new Date().toISOString() }]
          });
        }

        closeModal("demandaModal");
        renderAll();
        toast("Salvo localmente.");
        return;
      }

      if (id) {
        const cur = demandas.find(d => d.id === id);
        const hist = [...(Array.isArray(cur?.historico) ? cur.historico : []), ...histEntries];

        payload.historico = hist;
        payload.updated_at = new Date().toISOString();

        const { error } = await supabaseClient.from("jur_demandas").update(payload).eq("id", id);

        if (error) {
          toast(error.message, "error");
          return;
        }
      } else {
        payload.codigo = await nextCode();
        payload.historico = [{ msg: "Criado", data: new Date().toISOString() }];

        const { error } = await supabaseClient.from("jur_demandas").insert(payload);

        if (error) {
          toast(error.message, "error");
          return;
        }
      }

      closeModal("demandaModal");
      clearDemandaForm();
      await refresh();
      toast("Registro salvo.");
    }

    async function deleteDemanda() {
      const id = getValue("demandaId");

      if (!id || !confirm("Excluir este registro permanentemente?")) return;

      if (!supabaseClient) {
        demandas = demandas.filter(d => d.id !== id);
        closeModal("demandaModal");
        renderAll();
        toast("Excluído localmente.");
        return;
      }

      const { error } = await supabaseClient.from("jur_demandas").delete().eq("id", id);

      if (error) {
        toast(error.message, "error");
        return;
      }

      closeModal("demandaModal");
      await refresh();
      toast("Registro excluído.");
    }

    function dragCard(event, id) {
      draggedId = id;
      event.dataTransfer.effectAllowed = "move";
    }

    function allowDrop(event) {
      event.preventDefault();
      event.currentTarget.classList.add("drag-over");
    }

    function leaveDrop(event) {
      event.currentTarget.classList.remove("drag-over");
    }

    async function dropCard(event) {
      event.preventDefault();
      event.currentTarget.classList.remove("drag-over");

      const newStatus = event.currentTarget.dataset.status;

      if (!draggedId || !newStatus) return;

      const item = demandas.find(d => d.id === draggedId);
      if (!item) return;

      const oldStatus = item.status;

      if (oldStatus === newStatus) return;

      const histEntry = {
        msg: `Status alterado: ${STATUS_LABEL[oldStatus]} → ${STATUS_LABEL[newStatus]}`,
        data: new Date().toISOString()
      };

      const newHist = [...(Array.isArray(item.historico) ? item.historico : []), histEntry];

      if (!supabaseClient) {
        item.status = newStatus;
        item.historico = newHist;
        renderAll();
        toast(`Status → ${STATUS_LABEL[newStatus]}`);
        return;
      }

      const { error } = await supabaseClient
        .from("jur_demandas")
        .update({
          status: newStatus,
          historico: newHist,
          updated_at: new Date().toISOString()
        })
        .eq("id", draggedId);

      if (error) {
        toast(error.message, "error");
        return;
      }

      await refresh();
      toast(`Status → ${STATUS_LABEL[newStatus]}`);
    }

    function addChecklistItem() {
      const text = getValue("checkInput");

      if (!text) return;

      checklistAtual.push({
        text,
        done: false
      });

      setValue("checkInput", "");
      renderChecklist();
    }

    function toggleChecklist(i) {
      checklistAtual[i].done = !checklistAtual[i].done;
      renderChecklist();
    }

    function removeChecklist(i) {
      checklistAtual.splice(i, 1);
      renderChecklist();
    }

    function renderChecklist() {
      const box = document.getElementById("checklistBox");

      if (!checklistAtual.length) {
        box.innerHTML = '<div class="empty" style="padding:16px">Nenhum item no checklist.</div>';
        return;
      }

      box.innerHTML = checklistAtual.map((item, i) => `
        <div class="check-item">
          <input type="checkbox" ${item.done ? "checked" : ""} onchange="toggleChecklist(${i})" />
          <span class="${item.done ? "done" : ""}">${escapeHtml(item.text)}</span>
          <button type="button" class="btn btn-danger btn-xs" onclick="removeChecklist(${i})">✕</button>
        </div>
      `).join("");
    }

    function saveConfig() {
      localStorage.setItem("JUR_SUPABASE_URL", getValue("supabaseUrl"));
      localStorage.setItem("JUR_SUPABASE_KEY", getValue("supabaseKey"));
      location.reload();
    }

    function clearFilters() {
      ["searchInput", "filterTipo", "filterArea", "filterRisco", "filterResponsavel"].forEach(id => setValue(id, ""));
      renderAll();
    }

    function clearDemandaForm() {
      [
        "demandaId",
        "demandaOldStatus",
        "demandaOldResp",
        "titulo",
        "descricao",
        "prazo",
        "numeroProcesso",
        "valorEnvolvido",
        "parteContraria",
        "linkDocumento",
        "checkInput"
      ].forEach(id => setValue(id, ""));

      setValue("tipoRegistro", "demanda");
      setValue("status", "triagem");
      setValue("prioridade", "media");
      setValue("areaJuridica", "contratos");
      setValue("risco", "medio");
      setValue("responsavelSelect", "");

      checklistAtual = [];
      renderChecklist();
    }

    function openModal(id) {
      document.getElementById(id).classList.add("active");
    }

    function closeModal(id) {
      document.getElementById(id).classList.remove("active");
    }

    document.querySelectorAll(".modal-overlay").forEach(modal => {
      modal.addEventListener("click", e => {
        if (e.target === modal) modal.classList.remove("active");
      });
    });

    async function nextCode() {
      const year = new Date().getFullYear();
      const count = demandas.filter(d => String(d.codigo || "").includes(`JUR-${year}`)).length + 1;
      return `JUR-${year}-${String(count).padStart(4, "0")}`;
    }

    function nextLocalCode() {
      return `JUR-${new Date().getFullYear()}-${String(demandas.length + 1).padStart(4, "0")}`;
    }

    function getResponsavel(id) {
      return responsaveis.find(r => r.id === id);
    }

    function getPrazoClass(date) {
      if (!date) return "";

      const today = new Date();
      today.setHours(0, 0, 0, 0);

      const diff = Math.ceil((new Date(date + "T00:00:00") - today) / 86400000);

      if (diff < 0) return "overdue";
      if (diff <= 2) return "due-soon";

      return "";
    }

    const AREA_MAP = {
      contratos: "Contratos",
      trabalhista: "Trabalhista",
      civel: "Cível",
      tributario: "Tributário",
      societario: "Societário",
      compliance: "Compliance",
      lgpd: "LGPD",
      administrativo: "Administrativo"
    };

    const PRIO_MAP = {
      baixa: "Baixa",
      media: "Média",
      alta: "Alta",
      critico: "Crítica"
    };

    const RISCO_MAP = {
      baixo: "Baixo",
      medio: "Médio",
      alto: "Alto",
      critico: "Crítico"
    };

    function labelArea(v) {
      return AREA_MAP[v] || v || "—";
    }

    function labelPrioridade(v) {
      return PRIO_MAP[v] || v || "—";
    }

    function labelRisco(v) {
      return RISCO_MAP[v] || v || "—";
    }

    function formatDate(date) {
      if (!date) return "";

      const [y, m, d] = date.split("-");
      return `${d}/${m}/${y}`;
    }

    function formatMoney(v) {
      return Number(v || 0).toLocaleString("pt-BR", {
        style: "currency",
        currency: "BRL"
      });
    }

    function addDays(date, days) {
      const d = new Date(date);
      d.setDate(d.getDate() + days);
      return d;
    }

    function toISODate(date) {
      return date.toISOString().slice(0, 10);
    }

    function getValue(id) {
      return document.getElementById(id)?.value?.trim() || "";
    }

    function setValue(id, v) {
      const el = document.getElementById(id);
      if (el) el.value = v ?? "";
    }

    function escapeHtml(v) {
      return String(v ?? "").replace(/[&<>"']/g, c => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#039;"
      }[c]));
    }

    function toast(msg, type = "success") {
      const el = document.getElementById("toast");
      const icon = document.getElementById("toastIcon");

      el.style.borderColor = type === "error" ? "var(--red)" : type === "info" ? "var(--blue)" : "var(--green)";
      icon.textContent = type === "error" ? "✗" : type === "info" ? "ℹ" : "✓";

      document.getElementById("toastMsg").textContent = msg;

      el.classList.add("show");
      setTimeout(() => el.classList.remove("show"), 3500);
    }
  </script>
</body>
