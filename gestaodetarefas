<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>LexBoard — Gestão Jurídica</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <style>
    :root {
      --bg: #0d0f14;
      --surface: #151821;
      --surface2: #1c2030;
      --surface3: #222840;
      --border: #2a3050;
      --border2: #363f60;
      --text: #e8ecf8;
      --text2: #8b95b8;
      --text3: #556080;
      --gold: #c9a227;
      --gold2: #f0c84a;
      --blue: #4a80f5;
      --green: #2ecc87;
      --amber: #f5a623;
      --red: #f04040;
      --purple: #9b6bff;
      --radius: 14px;
      --shadow: 0 4px 24px rgba(0,0,0,.4);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: "DM Sans", sans-serif;
      min-height: 100vh;
      overflow: hidden;
    }

    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }

    ::-webkit-scrollbar-thumb {
      background: var(--border2);
      border-radius: 99px;
    }

    header {
      height: 68px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 22px;
      gap: 14px;
      position: relative;
      z-index: 10;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: fit-content;
    }

    .brand-icon {
      width: 38px;
      height: 38px;
      background: linear-gradient(135deg, var(--gold), var(--gold2));
      border-radius: 10px;
      display: grid;
      place-items: center;
      font-size: 20px;
    }

    .brand h1 {
      font-family: "Playfair Display", serif;
      font-size: 22px;
      color: var(--gold2);
      line-height: 1;
    }

    .brand p {
      font-size: 11px;
      color: var(--text3);
      margin-top: 3px;
    }

    .search-wrap {
      flex: 1;
      max-width: 520px;
      position: relative;
    }

    .search-wrap::before {
      content: "⌕";
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text3);
      font-size: 18px;
    }

    .search {
      width: 100%;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 12px 10px 38px;
      color: var(--text);
      font-size: 13px;
      outline: none;
    }

    .search:focus,
    input:focus,
    select:focus,
    textarea:focus {
      border-color: var(--gold);
    }

    .top-actions {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .btn {
      border: none;
      border-radius: 8px;
      padding: 9px 14px;
      cursor: pointer;
      font-weight: 600;
      font-size: 13px;
      font-family: "DM Sans", sans-serif;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
      transition: .15s;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--gold), var(--gold2));
      color: #0d0f14;
    }

    .btn-primary:hover {
      opacity: .9;
      transform: translateY(-1px);
    }

    .btn-secondary {
      background: var(--surface2);
      color: var(--text2);
      border: 1px solid var(--border);
    }

    .btn-secondary:hover {
      background: var(--surface3);
      color: var(--text);
    }

    .btn-danger {
      background: rgba(240,64,64,.15);
      color: var(--red);
      border: 1px solid rgba(240,64,64,.35);
    }

    .btn-ghost {
      background: transparent;
      color: var(--text3);
      border: 1px solid transparent;
    }

    .btn-ghost:hover {
      color: var(--text);
      background: var(--surface2);
    }

    .btn-sm {
      padding: 6px 10px;
      font-size: 12px;
      border-radius: 6px;
    }

    .btn-xs {
      padding: 4px 8px;
      font-size: 11px;
      border-radius: 5px;
    }

    .layout {
      height: calc(100vh - 68px);
      display: grid;
      grid-template-columns: 270px 1fr;
      overflow: hidden;
    }

    aside {
      background: var(--surface);
      border-right: 1px solid var(--border);
      padding: 16px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .panel {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px;
    }

    .panel-title {
      font-size: 10px;
      font-weight: 700;
      color: var(--text3);
      text-transform: uppercase;
      letter-spacing: .1em;
      margin-bottom: 12px;
    }

    .metric-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .metric {
      background: var(--surface3);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 10px;
    }

    .metric strong {
      display: block;
      font-size: 26px;
      font-family: "Playfair Display", serif;
      margin-bottom: 4px;
      color: var(--gold2);
    }

    .metric span {
      font-size: 11px;
      color: var(--text3);
    }

    .field {
      margin-bottom: 12px;
    }

    label {
      display: block;
      font-size: 11px;
      font-weight: 600;
      color: var(--text3);
      text-transform: uppercase;
      letter-spacing: .06em;
      margin-bottom: 6px;
    }

    input,
    select,
    textarea {
      width: 100%;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 12px;
      color: var(--text);
      font-size: 13px;
      font-family: "DM Sans", sans-serif;
      outline: none;
    }

    select option {
      background: var(--surface2);
    }

    textarea {
      min-height: 80px;
      resize: vertical;
    }

    main {
      padding: 16px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .board-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 14px;
    }

    .board-title h2 {
      font-family: "Playfair Display", serif;
      font-size: 26px;
      color: var(--text);
    }

    .board-title p {
      font-size: 12px;
      color: var(--text3);
      margin-top: 3px;
    }

    .view-tabs {
      display: flex;
      gap: 4px;
      background: var(--surface2);
      padding: 4px;
      border-radius: 8px;
      border: 1px solid var(--border);
    }

    .tab-btn {
      padding: 6px 14px;
      border-radius: 5px;
      border: none;
      background: transparent;
      color: var(--text3);
      cursor: pointer;
      font-size: 12px;
      font-weight: 600;
      font-family: "DM Sans", sans-serif;
    }

    .tab-btn.active {
      background: var(--gold);
      color: #0d0f14;
    }

    .board {
      flex: 1;
      overflow-x: auto;
      overflow-y: hidden;
      display: grid;
      grid-template-columns: repeat(5, minmax(260px, 1fr));
      gap: 12px;
      min-height: 0;
    }

    .column {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      display: flex;
      flex-direction: column;
      min-height: 0;
      overflow: hidden;
    }

    .column-header {
      padding: 12px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .column-header h3 {
      font-size: 13px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--text2);
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      display: inline-block;
    }

    .count {
      font-size: 11px;
      font-weight: 700;
      color: var(--text3);
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 3px 8px;
      border-radius: 999px;
    }

    .dropzone {
      flex: 1;
      min-height: 120px;
      overflow-y: auto;
      padding: 10px;
      transition: background .15s;
    }

    .dropzone.drag-over {
      background: rgba(201,162,39,.07);
    }

    .card {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px;
      margin-bottom: 8px;
      cursor: grab;
      transition: .15s;
      position: relative;
    }

    .card:hover {
      border-color: var(--border2);
      box-shadow: var(--shadow);
      transform: translateY(-1px);
    }

    .card::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      border-radius: 3px 0 0 3px;
      background: var(--border2);
    }

    .card.prio-critico::before { background: var(--red); }
    .card.prio-alta::before { background: var(--amber); }
    .card.prio-media::before { background: var(--blue); }
    .card.prio-baixa::before { background: var(--green); }

    .card h4 {
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 4px;
      line-height: 1.4;
    }

    .card-code {
      font-size: 10px;
      color: var(--text3);
      margin-bottom: 8px;
      font-family: monospace;
    }

    .badges {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin: 8px 0;
    }

    .badge {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      border-radius: 999px;
      padding: 3px 7px;
      letter-spacing: .04em;
    }

    .badge-demanda {
      background: rgba(74,128,245,.15);
      color: #6b9eff;
    }

    .badge-tarefa {
      background: rgba(155,107,255,.15);
      color: var(--purple);
    }

    .badge-baixa {
      background: rgba(46,204,135,.15);
      color: var(--green);
    }

    .badge-media {
      background: rgba(74,128,245,.15);
      color: #6b9eff;
    }

    .badge-alta {
      background: rgba(245,166,35,.15);
      color: var(--amber);
    }

    .badge-critico {
      background: rgba(240,64,64,.15);
      color: var(--red);
    }

    .card-desc {
      font-size: 12px;
      color: var(--text3);
      line-height: 1.5;
      margin: 6px 0;
    }

    .card-meta {
      font-size: 11px;
      color: var(--text3);
      display: grid;
      gap: 3px;
      margin-top: 8px;
    }

    .overdue {
      color: var(--red) !important;
      font-weight: 600;
    }

    .due-soon {
      color: var(--amber) !important;
      font-weight: 600;
    }

    .card-footer {
      margin-top: 10px;
      padding-top: 10px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .avatar {
      width: 24px;
      height: 24px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
    }

    .resp-label {
      font-size: 11px;
      color: var(--text3);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .empty {
      text-align: center;
      color: var(--text3);
      font-size: 12px;
      padding: 32px 8px;
      opacity: .7;
    }

    .modal-overlay {
      position: fixed;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: rgba(0,0,0,.75);
      backdrop-filter: blur(6px);
      z-index: 1000;
    }

    .modal-overlay.active {
      display: flex;
    }

    .modal {
      width: 820px;
      max-width: 96vw;
      max-height: 90vh;
      overflow-y: auto;
      background: var(--surface);
      border: 1px solid var(--border2);
      border-radius: 20px;
      box-shadow: 0 12px 48px rgba(0,0,0,.6);
    }

    .modal-lg {
      width: 960px;
    }

    .modal-header,
    .modal-footer {
      padding: 18px 22px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .modal-footer {
      border-top: 1px solid var(--border);
      border-bottom: none;
      justify-content: flex-end;
      gap: 8px;
    }

    .modal-body {
      padding: 20px 22px;
    }

    .modal-title {
      font-family: "Playfair Display", serif;
      font-size: 20px;
    }

    .modal-close {
      width: 32px;
      height: 32px;
      border: none;
      border-radius: 8px;
      background: var(--surface2);
      color: var(--text3);
      cursor: pointer;
      font-size: 18px;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .grid-3 {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px;
    }

    .section-divider {
      font-size: 11px;
      font-weight: 700;
      color: var(--text3);
      text-transform: uppercase;
      letter-spacing: .1em;
      border-top: 1px solid var(--border);
      padding-top: 14px;
      margin-top: 4px;
      margin-bottom: 12px;
    }

    .check-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 10px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 8px;
      margin-bottom: 6px;
    }

    .check-item input[type=checkbox] {
      width: 16px;
      height: 16px;
      accent-color: var(--gold);
    }

    .check-item span {
      flex: 1;
      font-size: 13px;
      color: var(--text2);
    }

    .check-item span.done {
      text-decoration: line-through;
      color: var(--text3);
    }

    .upcoming-item {
      padding: 9px 0;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
    }

    .upcoming-title {
      font-size: 12px;
      font-weight: 600;
    }

    .upcoming-date {
      font-size: 11px;
      color: var(--text3);
      margin-top: 3px;
    }

    .user-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 10px;
      background: var(--surface3);
      border: 1px solid var(--border);
      border-radius: 8px;
      margin-bottom: 8px;
    }

    .user-info {
      flex: 1;
      min-width: 0;
    }

    .user-name {
      font-size: 13px;
      font-weight: 600;
    }

    .user-meta {
      font-size: 11px;
      color: var(--text3);
    }

    .info-box {
      background: rgba(201,162,39,.07);
      border: 1px solid rgba(201,162,39,.25);
      border-radius: 10px;
      padding: 12px 14px;
      font-size: 12px;
      color: var(--text2);
      line-height: 1.6;
    }

    .toast {
      position: fixed;
      right: 16px;
      bottom: 16px;
      background: var(--surface);
      border: 1px solid var(--border2);
      color: var(--text);
      padding: 12px 16px;
      border-radius: 12px;
      font-size: 13px;
      transform: translateY(80px);
      opacity: 0;
      transition: .25s;
      z-index: 2000;
      max-width: 380px;
      display: flex;
      align-items: center;
      gap: 10px;
      box-shadow: 0 12px 48px rgba(0,0,0,.6);
    }

    .toast.show {
      transform: translateY(0);
      opacity: 1;
    }

    @media (max-width: 1024px) {
      body {
        overflow: auto;
      }

      header {
        height: auto;
        flex-wrap: wrap;
        padding: 14px;
      }

      .layout {
        height: auto;
        grid-template-columns: 1fr;
      }

      aside {
        display: none;
      }

      .board {
        grid-template-columns: repeat(5, 260px);
      }

      .grid-2,
      .grid-3 {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>
  <header>
    <div class="brand">
      <div class="brand-icon">⚖</div>
      <div>
        <h1>LexBoard</h1>
        <p>Gestão Jurídica Inteligente</p>
      </div>
    </div>

    <div class="search-wrap">
      <input
        id="searchInput"
        class="search"
        placeholder="Buscar por título, processo, parte, responsável..."
        oninput="renderAll()"
      />
    </div>

    <div class="top-actions">
      <button class="btn btn-ghost btn-sm" onclick="openModal('configModal')">⚙ Config</button>
      <button class="btn btn-secondary btn-sm" onclick="openModal('usersModal')">👥 Usuários</button>
      <button class="btn btn-primary" onclick="newDemanda()">+ Nova tarefa</button>
    </div>
  </header>

  <div class="layout">
    <aside>
      <div class="panel">
        <div class="panel-title">Indicadores</div>
        <div class="metric-grid">
          <div class="metric">
            <strong id="metricTotal">0</strong>
            <span>Total</span>
          </div>
          <div class="metric">
            <strong id="metricPrazo" style="color:var(--red)">0</strong>
            <span>Vencidas</span>
          </div>
          <div class="metric">
            <strong id="metricCritico" style="color:var(--amber)">0</strong>
            <span>Alto/Crítico</span>
          </div>
          <div class="metric">
            <strong id="metricConcluido" style="color:var(--green)">0</strong>
            <span>Concluídas</span>
          </div>
        </div>
      </div>

      <div class="panel">
        <div class="panel-title">Filtros</div>

        <div class="field">
          <label>Tipo</label>
          <select id="filterTipo" onchange="renderAll()">
            <option value="">Todos</option>
            <option value="demanda">Demandas</option>
            <option value="tarefa">Tarefas</option>
          </select>
        </div>

        <div class="field">
          <label>Área jurídica</label>
          <select id="filterArea" onchange="renderAll()">
            <option value="">Todas</option>
            <option value="contratos">Contratos</option>
            <option value="trabalhista">Trabalhista</option>
            <option value="civel">Cível</option>
            <option value="tributario">Tributário</option>
            <option value="societario">Societário</option>
            <option value="compliance">Compliance</option>
            <option value="lgpd">LGPD</option>
            <option value="administrativo">Administrativo</option>
          </select>
        </div>

        <div class="field">
          <label>Risco</label>
          <select id="filterRisco" onchange="renderAll()">
            <option value="">Todos</option>
            <option value="baixo">Baixo</option>
            <option value="medio">Médio</option>
            <option value="alto">Alto</option>
            <option value="critico">Crítico</option>
          </select>
        </div>

        <div class="field">
          <label>Responsável</label>
          <select id="filterResponsavel" onchange="renderAll()">
            <option value="">Todos</option>
          </select>
        </div>

        <button class="btn btn-ghost btn-sm" style="width:100%;justify-content:center" onclick="clearFilters()">
          ✕ Limpar filtros
        </button>
      </div>

      <div class="panel" style="flex:1">
        <div class="panel-title">Próximos prazos</div>
        <div id="upcomingList"></div>
      </div>
    </aside>

    <main>
      <div class="board-header">
        <div class="board-title">
          <h2>Quadro Jurídico</h2>
          <p>Arraste os cartões entre colunas para atualizar o status</p>
        </div>

        <div class="view-tabs">
          <button class="tab-btn active" onclick="switchView('kanban', this)">⊞ Kanban</button>
          <button class="tab-btn" onclick="switchView('lista', this)">≡ Lista</button>
        </div>
      </div>

      <section id="boardKanban" class="board"></section>
      <section id="boardLista" style="display:none;flex:1;overflow-y:auto"></section>
    </main>
  </div>

  <div class="modal-overlay" id="configModal">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title">Configuração Supabase</div>
        <button class="modal-close" onclick="closeModal('configModal')">×</button>
      </div>

      <div class="modal-body">
        <div class="info-box" style="margin-bottom:16px">
          <strong>Instruções rápidas</strong><br>
          Crie um projeto no Supabase, copie a URL e a chave <em>anon public</em> em
          <em>Settings → API</em> e cole abaixo.
        </div>

        <div class="field">
          <label>Supabase URL</label>
          <input id="supabaseUrl" placeholder="https://xxxxx.supabase.co" />
        </div>

        <div class="field">
          <label>Supabase anon key</label>
          <textarea id="supabaseKey" placeholder="eyJhbGciOi..." style="min-height:60px"></textarea>
        </div>

        <details style="margin-top:14px">
          <summary style="cursor:pointer;font-size:13px;color:var(--gold);font-weight:600">
            Ver SQL para criação das tabelas
          </summary>

          <pre style="margin-top:10px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:12px;font-size:11px;color:var(--text2);overflow-x:auto;white-space:pre-wrap">create extension if not exists "pgcrypto";

create table if not exists jur_responsaveis (
  id uuid primary key default gen_random_uuid(),
  nome text not null,
  email text,
  cargo text,
  cor text default '#4a80f5',
  alertas_email boolean default true,
  alerta_status boolean default true,
  alerta_prazo boolean default true,
  alerta_atrib boolean default true,
  created_at timestamptz default now()
);

create table if not exists jur_demandas (
  id uuid primary key default gen_random_uuid(),
  codigo text,
  tipo_registro text default 'tarefa',
  titulo text not null,
  descricao text,
  area_juridica text,
  risco text default 'medio',
  prioridade text default 'media',
  status text default 'triagem',
  responsavel_id uuid references jur_responsaveis(id) on delete set null,
  prazo date,
  numero_processo text,
  parte_contraria text,
  valor_envolvido numeric,
  link_documento text,
  checklist jsonb default '[]',
  historico jsonb default '[]',
  created_at timestamptz default now(),
  updated_at timestamptz default now()
);

alter table jur_responsaveis enable row level security;
alter table jur_demandas enable row level security;

drop policy if exists allow_all_responsaveis on jur_responsaveis;
create policy allow_all_responsaveis on jur_responsaveis for all using (true) with check (true);

drop policy if exists allow_all_demandas on jur_demandas;
create policy allow_all_demandas on jur_demandas for all using (true) with check (true);</pre>
