          alertas_email: true,
          alerta_status: true,
          alerta_prazo: true
        },
        {
          id: "r2",
          nome: "Rafael Lima",
          email: "rafael@escritorio.com",
          cargo: "Especialista Contratos",
          cor: "#9b6bff",
          alertas_email: true,
          alerta_status: true,
          alerta_prazo: true
        }
