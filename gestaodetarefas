          link_documento: "",
          checklist: [
            { text: "Ler minuta", done: true },
            { text: "Marcar pontos de risco", done: false }
          ],
          historico: []
        },
        {
          id: "d2",
          codigo: "JUR-2026-0002",
          tipo_registro: "tarefa",
          titulo: "Protocolar manifestação trabalhista",
          descricao: "Conferir documentos e protocolar peça no tribunal.",
          area_juridica: "trabalhista",
          risco: "alto",
          prioridade: "critico",
          status: "em_execucao",
          responsavel_id: "r1",
          prazo: toISODate(addDays(hoje, -1)),
          numero_processo: "0001234-56.2024.5.02.0001",
          parte_contraria: "Ex-colaborador",
          valor_envolvido: 42000,
          link_documento: "",
          checklist: [
            { text: "Conferir procuração", done: true },
            { text: "Protocolar peça", done: false }
          ],
